<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Jblog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Jblog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Aplica o tema salvo antes do primeiro paint para evitar flash do tema errado.
        Aplica qualquer valor salvo: um data-theme desconhecido apenas cai no :root
        (segue o SO), sem quebrar. O nonce é obrigatório — a CSP bloqueia inline sem ele. %>
    <script nonce="<%= content_security_policy_nonce %>">
      const theme = localStorage.getItem("theme");
      if (theme) document.documentElement.dataset.theme = theme;
    </script>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <%= link_to "jblog", root_path, class: "site-header__logo" %>
        <nav class="site-header__nav">
          <%= link_to "Posts", root_path %>
          <%= link_to "Buscar", search_path %>
          <% if authenticated? %>
            <%= link_to "Admin", admin_posts_path %>
            <%= button_to "Sair", session_path, method: :delete, class: "site-header__logout" %>
          <% else %>
            <%= link_to "Entrar", new_session_path %>
          <% end %>
          <%# Seletor de tema. "Sistema" = seguir o SO; as paletas estão no CSS como
              blocos [data-theme]. Para adicionar uma, é só mais uma <option> aqui. %>
          <select class="theme-select" data-controller="theme" data-action="change->theme#apply" aria-label="Tema">
            <option value="system">Sistema</option>
            <option value="light">Claro</option>
            <option value="dark">Escuro</option>
            <option value="catppuccin">Catppuccin</option>
            <option value="gruvbox">Gruvbox</option>
            <option value="kanagawa">Kanagawa</option>
          </select>
        </nav>
      </div>
    </header>

    <main class="container">
      <% if notice.present? %>
        <div class="flash flash--notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash flash--alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>jblog &copy; <%= Date.current.year %></p>
      </div>
    </footer>
  </body>
</html>
