<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "jblog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Jblog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Aplica o tema salvo antes do primeiro paint para evitar flash do tema errado.
        Aplica qualquer valor salvo: um data-theme desconhecido apenas cai no :root
        (segue o SO), sem quebrar. O nonce é obrigatório — a CSP bloqueia inline sem ele. %>
    <script nonce="<%= content_security_policy_nonce %>">
      const theme = localStorage.getItem("theme");
      if (theme) document.documentElement.dataset.theme = theme;
    </script>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Fontes do redesign (Bitter para títulos, Lora para texto, JetBrains Mono para
        código/badges). A CSP libera fonts.googleapis.com/fonts.gstatic.com para isto. %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,600;0,700;0,800;1,500&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <%= link_to "jblog", root_path, class: "site-header__logo" %>

      <nav class="site-header__nav">
        <%= link_to "Posts", root_path, class: "site-header__link" %>
        <% if authenticated? %>
          <%= link_to "Admin", admin_posts_path, class: "site-header__link" %>
          <%= button_to "Sair", session_path, method: :delete, class: "site-header__logout" %>
        <% end %>

        <a href="https://github.com/Arthur-Queiroz" title="GitHub" class="site-header__icon-link">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.73.5.98 5.24.98 11.52c0 5.01 3.25 9.26 7.77 10.76.57.1.78-.25.78-.55 0-.27-.01-1.16-.02-2.1-3.16.69-3.83-1.34-3.83-1.34-.52-1.31-1.26-1.66-1.26-1.66-1.03-.7.08-.69.08-.69 1.14.08 1.74 1.17 1.74 1.17 1.01 1.73 2.65 1.23 3.3.94.1-.73.4-1.23.72-1.51-2.52-.29-5.17-1.26-5.17-5.62 0-1.24.44-2.26 1.17-3.06-.12-.29-.51-1.45.11-3.02 0 0 .96-.31 3.14 1.17a10.9 10.9 0 0 1 5.72 0c2.18-1.48 3.14-1.17 3.14-1.17.62 1.57.23 2.73.11 3.02.73.8 1.17 1.82 1.17 3.06 0 4.37-2.66 5.33-5.19 5.61.41.35.77 1.04.77 2.11 0 1.52-.01 2.75-.01 3.12 0 .3.2.66.79.55 4.51-1.5 7.76-5.75 7.76-10.76C23.02 5.24 18.27.5 12 .5z"></path></svg>
        </a>

        <%# Busca direto no header (Enter envia para /search). Ctrl K foca o campo. %>
        <%= form_with url: search_path, method: :get, class: "header-search",
              data: { controller: "search-shortcut", action: "keydown@window->search-shortcut#focus" } do |form| %>
          <svg class="header-search__icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <%= form.search_field :q, placeholder: "Buscar...", class: "header-search__input",
                aria: { label: "Buscar" }, data: { search_shortcut_target: "input" } %>
          <kbd class="header-search__kbd">Ctrl K</kbd>
        <% end %>

        <%# Alternar claro/escuro. A galeria completa de temas continua em /settings. %>
        <button type="button" class="theme-toggle" title="Alternar tema" aria-label="Alternar tema"
                data-controller="theme-toggle" data-action="theme-toggle#toggle">
          <svg data-theme-toggle-target="moon" hidden width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
          <svg data-theme-toggle-target="sun" hidden width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg>
        </button>

        <%# Engrenagem → tela de configurações (galeria de temas com preview). %>
        <%= link_to settings_path, class: "settings-link", aria: { label: "Configurações" } do %>
          <svg class="settings-link__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="3"/>
            <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
          </svg>
        <% end %>
      </nav>
    </header>

    <main class="page">
      <% if notice.present? %>
        <div class="flash flash--notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash flash--alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <p>jblog &copy; <%= Date.current.year %></p>
    </footer>
  </body>
</html>
