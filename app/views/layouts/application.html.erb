<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Jblog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Jblog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Aplica o tema salvo antes do primeiro paint para evitar flash do tema errado.
        O nonce é obrigatório — a CSP bloqueia script inline sem ele. %>
    <script nonce="<%= content_security_policy_nonce %>">
      const theme = localStorage.getItem("theme");
      if (theme === "light" || theme === "dark") document.documentElement.dataset.theme = theme;
    </script>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <%= link_to "jblog", root_path, class: "site-header__logo" %>
        <nav class="site-header__nav">
          <%= link_to "Posts", root_path %>
          <%= link_to "Buscar", search_path %>
          <% if authenticated? %>
            <%= link_to "Admin", admin_posts_path %>
            <%= button_to "Sair", session_path, method: :delete, class: "site-header__logout" %>
          <% else %>
            <%= link_to "Entrar", new_session_path %>
          <% end %>
          <button type="button" class="theme-toggle" data-controller="theme" data-action="click->theme#toggle" aria-label="Alternar tema claro/escuro">
            <svg class="theme-toggle__icon theme-toggle__icon--moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
            <svg class="theme-toggle__icon theme-toggle__icon--sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main class="container">
      <% if notice.present? %>
        <div class="flash flash--notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash flash--alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>jblog &copy; <%= Date.current.year %></p>
      </div>
    </footer>
  </body>
</html>
