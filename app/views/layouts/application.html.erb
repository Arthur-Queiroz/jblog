<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Jblog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Jblog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Aplica o tema salvo antes do primeiro paint para evitar flash do tema errado.
        Aplica qualquer valor salvo: um data-theme desconhecido apenas cai no :root
        (segue o SO), sem quebrar. O nonce é obrigatório — a CSP bloqueia inline sem ele. %>
    <script nonce="<%= content_security_policy_nonce %>">
      const theme = localStorage.getItem("theme");
      if (theme) document.documentElement.dataset.theme = theme;
    </script>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <%= link_to "jblog", root_path, class: "site-header__logo" %>
        <nav class="site-header__nav">
          <%= link_to "Posts", root_path %>
          <%= link_to "Buscar", search_path %>
          <% if authenticated? %>
            <%= link_to "Admin", admin_posts_path %>
            <%= button_to "Sair", session_path, method: :delete, class: "site-header__logout" %>
          <% else %>
            <%= link_to "Entrar", new_session_path %>
          <% end %>
          <%# Engrenagem → tela de configurações (escolha de tema com preview). %>
          <%= link_to settings_path, class: "settings-link", aria: { label: "Configurações" } do %>
            <svg class="settings-link__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
            </svg>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="container">
      <% if notice.present? %>
        <div class="flash flash--notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash flash--alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>jblog &copy; <%= Date.current.year %></p>
      </div>
    </footer>
  </body>
</html>
