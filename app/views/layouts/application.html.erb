<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Jblog" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Jblog">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="container">
        <%= link_to "jblog", root_path, class: "site-header__logo" %>
        <nav class="site-header__nav">
          <%= link_to "Posts", root_path %>
          <%= link_to "Buscar", search_path %>
          <% if authenticated? %>
            <%= link_to "Admin", admin_posts_path %>
            <%= button_to "Sair", session_path, method: :delete, class: "site-header__logout" %>
          <% else %>
            <%= link_to "Entrar", new_session_path %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="container">
      <% if notice.present? %>
        <div class="flash flash--notice"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="flash flash--alert"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>jblog &copy; <%= Date.current.year %></p>
      </div>
    </footer>
  </body>
</html>
