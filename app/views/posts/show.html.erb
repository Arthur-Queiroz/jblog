<% content_for(:title, @post.title) %>

<article>
  <header class="post-header">
    <h1 class="post-header__title"><%= @post.title %></h1>
    <time class="post-header__date" datetime="<%= @post.published_at&.iso8601 %>">
      <%= @post.published_at&.strftime("%d de %B de %Y") %>
    </time>
  </header>

  <div class="post-content">
    <%= raw @post.body_html %>
  </div>
</article>

<%= link_to "← Voltar", root_path, class: "back-link" %>
