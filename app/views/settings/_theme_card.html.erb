<%# Um card = um botão que (1) renderiza no próprio tema, via data-theme, e
    (2) aplica esse tema ao clicar. O data-theme serve às DUAS coisas: o CSS usa o
    atributo para pintar o card e as bolinhas, e o controller lê o mesmo atributo
    para aplicar. As bolinhas mostram cores-chave da paleta. %>
<button type="button"
        class="theme-card"
        data-theme="<%= theme[:id] %>"
        data-action="click->theme#select"
        data-theme-target="card"
        aria-pressed="false">
  <% if theme[:id] == "system" %>
    <span class="theme-card__preview theme-card__preview--system">
      Segue o tema do dispositivo
    </span>
  <% else %>
    <span class="theme-card__preview">
      <span class="theme-card__swatches">
        <span class="theme-card__dot theme-card__dot--keyword"></span>
        <span class="theme-card__dot theme-card__dot--string"></span>
        <span class="theme-card__dot theme-card__dot--constant"></span>
      </span>
    </span>
  <% end %>
  <span class="theme-card__name">
    <%= theme[:name] %>
    <span class="theme-card__check" aria-hidden="true">✓</span>
  </span>
</button>
