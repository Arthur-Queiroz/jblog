<% content_for(:title, "Admin - Posts") %>

<div class="admin-header">
  <h1>Admin - Posts</h1>
  <%= link_to "Novo post", new_admin_post_path, class: "btn btn--primary" %>
</div>

<table class="admin-table">
  <thead>
    <tr>
      <th>Título</th>
      <th>Status</th>
      <th>Criado em</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    <% @posts.each do |post| %>
      <tr>
        <td><%= post.title %></td>
        <td>
          <span class="status-badge status-badge--<%= post.published? ? 'published' : 'draft' %>">
            <%= post.published? ? "Publicado" : "Rascunho" %>
          </span>
        </td>
        <td><%= post.created_at.strftime("%d/%m/%Y %H:%M") %></td>
        <td>
          <div class="admin-table__actions">
            <%= link_to "Editar", edit_admin_post_path(post), class: "btn btn--sm btn--secondary" %>
            <%= button_to "Remover", admin_post_path(post), method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "btn btn--sm btn--danger" %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
