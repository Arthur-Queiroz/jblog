<%= form_with model: [:admin, post], class: "form", data: { controller: "preview" } do |form| %>
  <% if post.errors.any? %>
    <div class="form__errors">
      <h2><%= pluralize(post.errors.count, "erro") %> impedem o salvamento:</h2>
      <ul>
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form__group">
    <%= form.label :title, "Título", class: "form__label" %>
    <%= form.text_field :title, class: "form__input" %>
  </div>

  <div class="form__group">
    <%= form.label :slug, "Slug", class: "form__label" %>
    <%= form.text_field :slug, class: "form__input" %>
    <small class="form__hint">Deixe em branco para gerar automaticamente a partir do título.</small>
  </div>

  <div class="form__group">
    <%= form.label :body_markdown, "Conteúdo (Markdown)", class: "form__label" %>
    <%= form.text_area :body_markdown, rows: 20, class: "form__textarea", data: { preview_target: "input" } %>
    <button type="button" class="btn btn--secondary form__preview-button" data-action="click->preview#preview">
      Preview
    </button>
    <div class="preview-pane hidden" data-preview-target="output"></div>
  </div>

  <div class="form__group">
    <div class="form__checkbox-group">
      <%= form.check_box :published %>
      <%= form.label :published, "Publicado" %>
    </div>
  </div>

  <div class="form__group">
    <%= form.label :published_at, "Data de publicação", class: "form__label" %>
    <%= form.datetime_field :published_at, class: "form__input" %>
  </div>

  <div class="form__group">
    <%= form.submit class: "btn btn--primary" %>
  </div>
<% end %>
